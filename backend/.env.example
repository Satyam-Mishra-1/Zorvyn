PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/finance_dashboard
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
ALLOW_PUBLIC_REGISTER=true
NODE_ENV=development

# Frontend origins allowed by CORS (comma-separated). Include your Vercel URL after deploy.
# Example: https://finance-ui.vercel.app,http://localhost:5173
# Leave unset for development convenience (reflects request Origin).
CORS_ORIGIN=
